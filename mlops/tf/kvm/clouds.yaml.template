# IMPORTANT: Do NOT commit this file with real credentials!
# This is a template. Fill in your application_credential_id and application_credential_secret
# from the clouds.yaml you download from the KVM@TACC Horizon GUI.
#
# Steps:
# 1. chameleoncloud.org -> Experiment -> KVM@TACC
# 2. Identity -> Application Credentials -> Create Application Credential
#    - Name: mlops-lab
#    - Expiration: project deadline (May 4, 2026)
# 3. Click "Download clouds.yaml", then copy the credential_id/secret below.
# 4. Save the real file as `clouds.yaml` (NOT `.template`) in this same directory.

clouds:
  openstack:
    auth:
      auth_url: https://kvm.tacc.chameleoncloud.org:5000
      application_credential_id: "REDACTED_UNIQUE_ID"
      application_credential_secret: "REDACTED_SECRET"
    region_name: "KVM@TACC"
    interface: "public"
    identity_api_version: 3
    auth_type: "v3applicationcredential"
